{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/your-org/research-wiki/schemas/paper.schema.json",
  "title": "PaperFrontmatter",
  "description": "YAML frontmatter for literature-kb/02_Literature/Papers/<id>.md. Mirrors lgrlw.schemas.PaperFrontmatter.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "id", "title", "authors", "year", "added_on"],
  "properties": {
    "type": {"const": "paper"},
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
    },
    "title":   {"type": "string", "minLength": 3},
    "authors": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "year":    {"type": "integer", "minimum": 1900, "maximum": 2100},
    "venue":   {"type": ["string", "null"]},
    "doi":     {"type": ["string", "null"], "pattern": "^10\\.\\d{4,9}/\\S+$"},
    "arxiv_id": {
      "type": ["string", "null"],
      "pattern": "^(?:\\d{4}\\.\\d{4,5}(?:v\\d+)?|[a-z\\-]+(?:\\.[A-Z]{2})?/\\d{7}(?:v\\d+)?)$"
    },
    "openalex_id":         {"type": ["string", "null"], "pattern": "^W\\d+$"},
    "semantic_scholar_id": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "url":                 {"type": ["string", "null"]},
    "status": {"enum": ["published", "accepted", "preprint"]},
    "source": {"enum": ["manual", "arxiv", "openalex", "semantic_scholar", "crossref", "doi", "promoted"]},
    "added_on": {"type": "string", "format": "date"},
    "tags":     {"type": "array", "items": {"type": "string"}, "default": []}
  }
}
